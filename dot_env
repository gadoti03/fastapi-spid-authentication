# in production, these would be set to secure values
#   app_user: permits for the application to access and modify the database
#       CONNECT, USAGE, CREATE sullo schema
#       SELECT/INSERT/UPDATE/DELETE sulle tabelle necessarie
#   admin: full database admin rights
#   read_only: read-only access to the database
DATABASE_URL=postgresql+psycopg2://<user>:<password>@localhost:<port>/<name_db>

FRONTEND_PATH="https://localhost:5173"

# PATH SETTINGS
IDPS_FILE="/<...>/fastapi-spid-authentication/spid/static/idps_data.json"
METADATA_FILE="/<...>/fastapi-spid-authentication/spid/static/metadata.xml"

# SPID SETTINGS
COMMON_NAME="Comune di Roma"
DAYS="3650"
ENTITY_ID="https://spid.comune.roma.it/metadata"
NAME_QUALIFIER="https://spid.comune.roma.it/metadata"
ACS_URL="https://spid.comune.roma.it/acs"
KEY_LEN="3072"
LOCALITY_NAME="Roma"
MD_ALG="sha512"
ORGANIZATION_IDENTIFIER="PA:IT-c_h501"
ORGANIZATION_NAME="Comune di Roma"

# OTHER SETTINGS
URL_ROOT="http://localhost:8000"

# METADATA SETTINGS
CERT_DIR_PATH="/<...>/fastapi-spid-authentication/spid/static/certs/"
METADATA_PATH="/<...>/fastapi-spid-authentication/spid/static/metadata.xml"
METADATA_CLEAN_PATH="/<...>/fastapi-spid-authentication/spid/static/metadata-clean.xml"

# DATA CONSTRAINTS
REQUIRED_RESIDENCE = "Roma"